{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Untold Lang",
  "scopeName": "source.untold",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#modules" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.untold",
          "match": "//.*$"
        },
        {
          "name": "comment.block.untold",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.untold",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.untold",
          "match": "\\\\."
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.untold",
          "match": "\\b(if|elif|else|loop|while|in|break|skip|try|catch|finally|return|wait)\\b"
        },
        {
          "name": "keyword.declaration.untold",
          "match": "\\b(let|lock|fn|async|class|use|start|self)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.untold",
      "match": "\\b(num|text|bool|list|map|void|any|byte|func)\\b"
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.untold",
          "match": "\\b(true|false|null)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.untold",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
        },
        {
          "name": "entity.name.type.class.untold",
          "match": "\\b([A-Z][a-zA-Z0-9_]*)\\b"
        }
      ]
    },
    "modules": {
      "name": "entity.name.namespace.untold",
      "match": "\\b(untold\\.[a-z]+)\\b"
    },
    "numbers": {
      "name": "constant.numeric.untold",
      "match": "\\b([0-9]+\\.?[0-9]*)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.untold",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.untold",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.arrow.untold",
          "match": "(->|\\.\\.|)"  
        },
        {
          "name": "keyword.operator.assignment.untold",
          "match": "(?<![=!<>])=(?!=)"
        },
        {
          "name": "keyword.operator.arithmetic.untold",
          "match": "(\\+|-|\\*|/|%)"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.braces.untold",
          "match": "[{}]"
        },
        {
          "name": "punctuation.section.parens.untold",
          "match": "[()]"
        },
        {
          "name": "punctuation.separator.untold",
          "match": "[,:]"
        }
      ]
    }
  }
}