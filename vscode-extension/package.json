{
  "name": "untold",
  "displayName": "Untold",
  "description": "Untold Lang v2.0.0 - The Language Without Limits. Syntax highlighting, REPL, debugger and run support for Untold Lang (.ut files)",
  "version": "2.0.0",
  "publisher": "thedrjude",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Debuggers"
  ],
  "activationEvents": [
    "onLanguage:untold"
  ],
  "main": "./extension.js",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/thedrjude/untold-lang"
  },
  "bugs": {
    "url": "https://github.com/thedrjude/untold-lang/issues"
  },
  "contributes": {
    "languages": [
      {
        "id": "untold",
        "aliases": [
          "Untold Lang",
          "untold"
        ],
        "extensions": [
          ".ut"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "untold",
        "scopeName": "source.untold",
        "path": "./syntaxes/untold.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "untold",
        "path": "./snippets/untold.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "untold.runFile",
        "title": "Untold: Run File",
        "icon": "$(play)"
      },
      {
        "command": "untold.checkFile",
        "title": "Untold: Check Syntax"
      },
      {
        "command": "untold.startRepl",
        "title": "Untold: Start REPL"
      },
      {
        "command": "untold.startDebugger",
        "title": "Untold: Start Debugger"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "untold.runFile",
          "when": "resourceExtname == .ut",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "untold.runFile",
          "when": "resourceExtname == .ut",
          "group": "untold"
        },
        {
          "command": "untold.checkFile",
          "when": "resourceExtname == .ut",
          "group": "untold"
        },
        {
          "command": "untold.startRepl",
          "when": "resourceExtname == .ut",
          "group": "untold@1"
        },
        {
          "command": "untold.startDebugger",
          "when": "resourceExtname == .ut",
          "group": "untold@1"
        }
      ]
    },
    "keybindings": [
      {
        "command": "untold.runFile",
        "key": "ctrl+shift+r",
        "when": "resourceExtname == .ut"
      },
      {
        "command": "untold.startRepl",
        "key": "ctrl+shift+l",
        "when": "resourceExtname == .ut"
      }
    ],
    "configuration": {
      "title": "Untold Lang",
      "properties": {
        "untold.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python interpreter used to run Untold Lang"
        },
        "untold.cliPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Untold Lang cli/main.py (auto-detected if empty)"
        }
      }
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "untold",
    "programming-language",
    "interpreter",
    "compiler",
    "scripting",
    "ai",
    "web"
  ],
  "author": {
    "name": "Antony Jude",
    "email": "thedrjude@github.com"
  },
  "license": "MIT"
}
